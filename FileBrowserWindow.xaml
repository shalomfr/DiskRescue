<Window x:Class="DiskRescue.FileBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="דפדפן קבצים ו-Undelete" Height="680" Width="1000" MinHeight="560" MinWidth="820"
        FlowDirection="RightToLeft" FontFamily="Segoe UI Variable Text, Segoe UI"
        WindowStartupLocation="CenterOwner" Background="{StaticResource Bg0Brush}" UseLayoutRounding="True">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- header -->
        <Border Grid.Row="0" CornerRadius="16" Padding="20,16" Background="{StaticResource HeaderGradient}"
                BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="12" Background="{StaticResource AccentGradient}">
                    <TextBlock Text="🗂" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtHeader" Text="דפדפן קבצים" Style="{StaticResource H1}"/>
                    <TextBlock Text="קריאה בלבד מה-MFT · קבצים קיימים ונמחקים עם הנתיב המקורי · שחזור לכונן אחר"
                               Style="{StaticResource Body}" Margin="0,1,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- controls card -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="מקס׳ רשומות" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtMax" Text="300000" Width="100" FlowDirection="LeftToRight"/>
                    <Button x:Name="BtnScan" Content="🔍  סרוק" Style="{StaticResource BtnPrimary}" Margin="10,0,0,0" Click="BtnScan_Click"/>
                    <Button x:Name="BtnCancel" Content="בטל" Style="{StaticResource BtnDanger}" Margin="8,0,0,0" IsEnabled="False" Click="BtnCancel_Click"/>
                    <ProgressBar x:Name="Bar" Width="220" Margin="14,0,0,0" VerticalAlignment="Center" Minimum="0" Maximum="100"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                    <CheckBox x:Name="ChkDeletedOnly" Content="נמחקים בלבד" VerticalAlignment="Center" Click="Filter_Changed"/>
                    <TextBlock Text="חיפוש" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" Margin="20,0,10,0"/>
                    <TextBox x:Name="TxtSearch" Width="280" TextChanged="Filter_Changed"/>
                    <TextBlock x:Name="TxtCount" Margin="18,0,0,0" VerticalAlignment="Center" Style="{StaticResource Caption}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- grid -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="8">
            <DataGrid x:Name="GridFiles" Style="{StaticResource DataGridModern}" SelectionMode="Extended">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="מצב" Binding="{Binding State}" Width="80"/>
                    <DataGridTextColumn Header="סוג" Binding="{Binding Type}" Width="56"/>
                    <DataGridTextColumn Header="גודל" Binding="{Binding SizeText}" Width="100"/>
                    <DataGridTextColumn Header="נתיב מקורי" Binding="{Binding FullPath}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- footer -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,16,0,0" Padding="14,12">
            <DockPanel>
                <Button x:Name="BtnRecover" DockPanel.Dock="left" Content="💾  שחזר נבחרים…"
                        Style="{StaticResource BtnSuccess}" Click="BtnRecover_Click"/>
                <TextBlock x:Name="TxtStatus" Margin="14,0,0,0" VerticalAlignment="Center"
                           Style="{StaticResource Caption}" Text="לחץ ‘סרוק’ כדי להתחיל."/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
