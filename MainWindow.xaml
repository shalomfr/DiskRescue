<Window x:Class="DiskRescue.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DiskRescue — אבחון לפני שחזור" Height="720" Width="1120" MinHeight="560" MinWidth="900"
        FlowDirection="RightToLeft" FontFamily="Segoe UI Variable Text, Segoe UI"
        WindowStartupLocation="CenterScreen" Background="{StaticResource Bg0Brush}"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== Header band ===== -->
        <Border Grid.Row="0" CornerRadius="16" Padding="22,18" Background="{StaticResource HeaderGradient}"
                BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="46" Height="46" CornerRadius="12" Background="{StaticResource AccentGradient}">
                        <TextBlock Text="🛟" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="DiskRescue" Style="{StaticResource H1}"/>
                        <TextBlock Text="קודם אבחון מהיר — ורק אם צריך, שחזור" Style="{StaticResource Body}" Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>
                <Border Grid.Column="1" VerticalAlignment="Center" CornerRadius="20" Margin="16,0,0,0"
                        Background="#1AFFFFFF" Padding="12,6" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="קריאה בלבד כברירת מחדל" Margin="8,0,0,0" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ===== Body ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="440"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: volumes -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,18,0">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="כוננים" Style="{StaticResource H2}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" x:Name="BtnRefresh" Content="רענן" Padding="14,6" Click="BtnRefresh_Click"/>
                    </Grid>

                    <StackPanel DockPanel.Dock="Bottom" Margin="0,14,0,0">
                        <Button x:Name="BtnDiagnose" Content="אבחן את הכונן שנבחר"
                                Style="{StaticResource BtnPrimary}" Padding="0,11" Click="BtnDiagnose_Click"/>
                        <Button x:Name="BtnDeepScan" Content="שחזור עמוק (Deep Scan)"
                                Margin="0,8,0,0" Padding="0,10" Click="BtnDeepScan_Click"/>
                        <Button x:Name="BtnBrowse" Content="דפדפן קבצים ו-Undelete (NTFS)"
                                Margin="0,8,0,0" Padding="0,10" Click="BtnBrowse_Click"/>
                        <Button x:Name="BtnImaging" Content="שכפול דיסק (Imaging) + SMART"
                                Margin="0,8,0,0" Padding="0,10" Click="BtnImaging_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="GridVolumes" Style="{StaticResource DataGridModern}"
                              SelectionChanged="GridVolumes_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="כונן" Binding="{Binding LetterDisplay}" Width="56"/>
                            <DataGridTextColumn Header="תווית" Binding="{Binding Label}" Width="*"/>
                            <DataGridTextColumn Header="מערכת" Binding="{Binding FsDisplay}" Width="90"/>
                            <DataGridTextColumn Header="גודל" Binding="{Binding SizeDisplay}" Width="80"/>
                            <DataGridTextColumn Header="בריאות" Binding="{Binding HealthDisplay}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Right: diagnosis -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <DockPanel>
                    <Border x:Name="SeverityBar" DockPanel.Dock="Top" CornerRadius="12" Padding="16,14"
                            Background="{StaticResource Bg2Brush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="SeverityDot" Width="10" Height="10" CornerRadius="5"
                                        Background="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtTitle" Text="בחר כונן ולחץ ‘אבחן’" Style="{StaticResource H2}"
                                           Margin="10,0,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtSubtitle" Text="" Style="{StaticResource Caption}" Margin="20,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="ממצאים" Style="{StaticResource SectionLabel}" Margin="2,16,0,6"/>
                            <ItemsControl x:Name="ListFindings">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="5" Height="5" CornerRadius="3" Margin="0,7,10,0"
                                                    VerticalAlignment="Top" Background="{StaticResource AccentBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding}" TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13.5"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="פעולות מומלצות" Style="{StaticResource SectionLabel}" Margin="2,18,0,6"/>
                            <StackPanel x:Name="PanelActions"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Border DockPanel.Dock="Bottom" Style="{StaticResource Card}" Margin="0,14,0,0"
                            Background="{StaticResource Bg0Brush}" Padding="0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="יומן" Style="{StaticResource SectionLabel}" Margin="14,12,0,0"/>
                            <TextBox x:Name="TxtLog" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     Background="Transparent" BorderThickness="0" Foreground="#FF8FE3A4"
                                     FontFamily="Cascadia Code, Consolas" FontSize="12" MinHeight="96" Margin="6"
                                     FlowDirection="LeftToRight"/>
                        </DockPanel>
                    </Border>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ===== Footer ===== -->
        <Border Grid.Row="2" Margin="0,16,0,0" CornerRadius="10" Background="{StaticResource Bg1Brush}"
                BorderBrush="{StaticResource StrokeSoftBrush}" BorderThickness="1" Padding="14,9">
            <TextBlock x:Name="TxtStatus" Style="{StaticResource Caption}" Text="מוכן."/>
        </Border>
    </Grid>
</Window>
