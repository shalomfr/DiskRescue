<Window x:Class="DiskRescue.DeepScanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="שחזור עמוק (Deep Scan)" Height="660" Width="940" MinHeight="540" MinWidth="780"
        FlowDirection="RightToLeft" FontFamily="Segoe UI Variable Text, Segoe UI"
        WindowStartupLocation="CenterOwner" Background="{StaticResource Bg0Brush}" UseLayoutRounding="True">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- header -->
        <Border Grid.Row="0" CornerRadius="16" Padding="20,16" Background="{StaticResource HeaderGradient}"
                BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="12" Background="{StaticResource AccentGradient}">
                    <TextBlock Text="🔬" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtHeader" Text="שחזור עמוק" Style="{StaticResource H1}"/>
                    <TextBlock Text="חיתוך לפי חתימות קבצים · השהיה, שמירת פרויקט והמשך, שחזור לפי סוג"
                               Style="{StaticResource Body}" Margin="0,1,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- controls card -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="תיקיית יעד" Style="{StaticResource SectionLabel}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBox Grid.Column="1" x:Name="TxtOut" FlowDirection="LeftToRight"/>
                    <Button Grid.Column="2" x:Name="BtnBrowse" Content="בחר…" Margin="10,0,0,0" Click="BtnBrowse_Click"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                    <Button x:Name="BtnStart" Content="▶  התחל" Style="{StaticResource BtnSuccess}" Click="BtnStart_Click"/>
                    <Button x:Name="BtnPause" Content="⏸  השהה" Style="{StaticResource BtnWarning}" Margin="8,0,0,0" IsEnabled="False" Click="BtnPause_Click"/>
                    <Button x:Name="BtnStop" Content="⏹  עצור" Style="{StaticResource BtnDanger}" Margin="8,0,0,0" IsEnabled="False" Click="BtnStop_Click"/>
                    <Rectangle Width="1" Margin="14,2" Fill="{StaticResource StrokeBrush}"/>
                    <Button x:Name="BtnSave" Content="💾  שמור פרויקט" Margin="0,0,8,0" Click="BtnSave_Click"/>
                    <Button x:Name="BtnLoad" Content="📂  טען פרויקט" Click="BtnLoad_Click"/>
                </StackPanel>

                <ProgressBar x:Name="Bar" Margin="0,16,0,0" Minimum="0" Maximum="100"/>
                <TextBlock x:Name="TxtStats" Margin="0,10,0,0" Style="{StaticResource Caption}"
                           Text="מוכן. בחר תיקיית יעד ולחץ ‘התחל’."/>
            </StackPanel>
        </Border>

        <!-- results -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="קבצים ששוחזרו" Style="{StaticResource SectionLabel}" Margin="10,8,0,8"/>
                <DataGrid x:Name="GridFiles" Style="{StaticResource DataGridModern}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="סוג" Binding="{Binding Ext}" Width="80"/>
                        <DataGridTextColumn Header="היסט" Binding="{Binding Offset}" Width="150"/>
                        <DataGridTextColumn Header="גודל (B)" Binding="{Binding Size}" Width="120"/>
                        <DataGridTextColumn Header="קובץ" Binding="{Binding Path}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</Window>
